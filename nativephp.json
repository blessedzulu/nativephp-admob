            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.HideBanner"
        },
        {
            "name": "Admob.LoadInterstitial",
            "ios": "AdmobFunctions.LoadInterstitial",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.LoadInterstitial"
        },
        {
            "name": "Admob.InterstitialReady",
            "ios": "AdmobFunctions.InterstitialReady",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.InterstitialReady"
        },
        {
            "name": "Admob.ShowInterstitial",
            "ios": "AdmobFunctions.ShowInterstitial",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.ShowInterstitial"
        },
        {
            "name": "Admob.LoadRewarded",
            "ios": "AdmobFunctions.LoadRewarded",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.LoadRewarded"
        },
        {
            "name": "Admob.RewardedReady",
            "ios": "AdmobFunctions.RewardedReady",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.RewardedReady"
        },
        {
            "name": "Admob.ShowRewarded",
            "ios": "AdmobFunctions.ShowRewarded",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.ShowRewarded"
        },
        {
            "name": "Admob.LoadRewardedInterstitial",
            "ios": "AdmobFunctions.LoadRewardedInterstitial",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.LoadRewardedInterstitial"
        },
        {
            "name": "Admob.RewardedInterstitialReady",
            "ios": "AdmobFunctions.RewardedInterstitialReady",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.RewardedInterstitialReady"
        },
        {
            "name": "Admob.ShowRewardedInterstitial",
            "ios": "AdmobFunctions.ShowRewardedInterstitial",
