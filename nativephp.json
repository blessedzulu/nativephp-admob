        {
            "name": "Admob.LoadAppOpen",
            "ios": "AdmobFunctions.LoadAppOpen",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.LoadAppOpen"
        },
        {
            "name": "Admob.AppOpenReady",
            "ios": "AdmobFunctions.AppOpenReady",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.AppOpenReady"
        },
        {
            "name": "Admob.ShowAppOpen",
            "ios": "AdmobFunctions.ShowAppOpen",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.ShowAppOpen"
        },
        {
            "name": "Admob.SetAppOpenSuppressed",
            "ios": "AdmobFunctions.SetAppOpenSuppressed",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.SetAppOpenSuppressed"
        },
        {
            "name": "Admob.UmpRequestInfo",
            "ios": "AdmobFunctions.UmpRequestInfo",
