        {
            "name": "Admob.UmpCanRequestAds",
            "ios": "AdmobFunctions.UmpCanRequestAds",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.UmpCanRequestAds"
        },
        {
            "name": "Admob.UmpStatus",
            "ios": "AdmobFunctions.UmpStatus",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.UmpStatus"
        },
        {
            "name": "Admob.UmpReset",
            "ios": "AdmobFunctions.UmpReset",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.UmpReset"
        },
        {
            "name": "Admob.AttRequest",
            "ios": "AdmobFunctions.AttRequest",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.AttRequest"
        },
        {
            "name": "Admob.AttStatus",
            "ios": "AdmobFunctions.AttStatus",
            "android": "com.blessedzulu.nativephp.admob.AdmobFunctions.AttStatus"
        }
    ],
    "events": [
        "BlessedZulu\\NativePhpAdmob\\Events\\AdLoaded",
        "BlessedZulu\\NativePhpAdmob\\Events\\AdFailedToLoad",
        "BlessedZulu\\NativePhpAdmob\\Events\\AdShown",
        "BlessedZulu\\NativePhpAdmob\\Events\\AdDismissed",
        "BlessedZulu\\NativePhpAdmob\\Events\\AdFailedToShow",
        "BlessedZulu\\NativePhpAdmob\\Events\\AdImpression",
        "BlessedZulu\\NativePhpAdmob\\Events\\AdClicked",
        "BlessedZulu\\NativePhpAdmob\\Events\\UserEarnedReward",
        "BlessedZulu\\NativePhpAdmob\\Events\\ConsentFormShown",
        "BlessedZulu\\NativePhpAdmob\\Events\\ConsentFormDismissed",
        "BlessedZulu\\NativePhpAdmob\\Events\\ConsentChanged",
        "BlessedZulu\\NativePhpAdmob\\Events\\TrackingAuthorizationGranted",
        "BlessedZulu\\NativePhpAdmob\\Events\\TrackingAuthorizationDenied"
    ],
    "android": {
        "permissions": [
            "android.permission.INTERNET",
            "android.permission.ACCESS_NETWORK_STATE"
        ],
        "dependencies": {
            "implementation": [
                "com.google.android.gms:play-services-ads:24.0.0",
                "com.google.android.ump:user-messaging-platform:3.0.0"
            ]
        },
        "meta_data": [
            {
                "name": "com.google.android.gms.ads.APPLICATION_ID",
                "value": "${ADMOB_APP_ID}"
            }
        ],
        "activities": [],
        "init_function": "com.blessedzulu.nativephp.admob.AdmobInit.initialize",
        "min_version": 26
    },
    "ios": {
        "info_plist": {
            "GADApplicationIdentifier": "${ADMOB_APP_ID}",
            "NSUserTrackingUsageDescription": "Your data helps us show ads that are relevant to you."
        },
        "dependencies": {
            "pods": [
                {"name": "Google-Mobile-Ads-SDK", "version": "~> 13.4"},
                {"name": "GoogleUserMessagingPlatform", "version": "~> 2.7"}
            ]
        },
        "init_function": "AdmobInit.initialize",
        "min_version": "18.0"
    },
    "hooks": {
        "post_compile": "nativephp:admob:substitute-placeholders"
    },
    "secrets": {
        "ADMOB_APP_ID": {
            "description": "AdMob app ID (ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY) from apps.admob.com. Single-platform apps can set just this. For separate Android + iOS apps set ADMOB_APP_ID_ANDROID and ADMOB_APP_ID_IOS instead - they override per build. The app ID is validated per-platform at compile time (the substitute-placeholders hook fails the build if the target platform's app ID is missing), so this key is not required globally.",
            "required": false
        },
        "ADMOB_APP_ID_ANDROID": {
            "description": "Android AdMob app ID (ca-app-pub-XXXX~YYYY). Used for Android builds; falls back to ADMOB_APP_ID.",
            "required": false
        },
        "ADMOB_APP_ID_IOS": {
            "description": "iOS AdMob app ID (ca-app-pub-XXXX~YYYY). Used for iOS builds; falls back to ADMOB_APP_ID.",
            "required": false
        }
    }
}
